# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Your Telegram Bot Token (from @BotFather)
VITE_BOT_TOKEN=your_bot_token_here

# The Chat ID of your Telegram group where orders will be sent
# To get it: add @userinfobot to your group, it will show the ID
VITE_ORDER_CHAT_ID=-5125344595

